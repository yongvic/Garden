// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Auth.js required tables
model User {
  id                    String       @id @default(cuid())
  name                  String?
  email                 String?      @unique
  emailVerified         DateTime?
  image                 String?
  password              String?      // for custom auth
  phone                 String?      // WhatsApp number (format: +228XXXXXXXX)
  isVerified            Boolean      @default(false)
  role                  Role         @default(CUSTOMER)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  // Relations
  accounts              Account[]
  sessions              Session[]
  listings              Listing[]
  bookings              Booking[]
  reviews               Review[]
  damageClaims          DamageClaim[]
  notifications         Notification[]
  favorites             Favorite[]
  sentMessages          Message[]
  conversationsAsCustomer Conversation[] @relation("CustomerConversations")
  conversationsAsLandlord Conversation[] @relation("LandlordConversations")
  invoices              Invoice[]
  quoteRequests         QuoteRequest[]
  hostReviewsGiven      HostReview[]     @relation("HostReviews")
  hostReviewsReceived   HostReview[]     @relation("GuestReviews")
  loyaltyAccount        LoyaltyAccount?
  referralCode          ReferralCode?
  referralsMade         Referral[]         @relation("Referrer")
  referralsReceived     Referral[]         @relation("Referred")
  sharedFavoriteLists   SharedFavoriteList[]
  landlordOnboarding    LandlordOnboarding?
  modificationRequests  BookingModificationRequest[] @relation("ModificationRequester")

  @@index([email])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Domain Models
enum Role {
  CUSTOMER
  LANDLORD
  ADMIN
}

enum ListingType {
  ROOM
  EQUIPMENT
  SPACE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DamageStatus {
  REPORTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SETTLED
}

enum BookingMode {
  INSTANT
  REQUEST
}

enum BookingPricingType {
  DAILY
  HOURLY
}

enum PricingRuleType {
  WEEKEND
  SEASON
  LONG_STAY
}

enum InvoiceType {
  CLIENT
  HOST
}

enum QuoteStatus {
  PENDING
  QUOTED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ModificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventPackageType {
  WEDDING
  CONFERENCE
  FILMING
  OTHER
}

model Listing {
  id                  String       @id @default(cuid())
  title               String
  description         String       @db.Text
  type                ListingType
  location            String
  latitude            Float?
  longitude           Float?
  pricePerDay         Float        // In cents to avoid floating point issues
  maxOccupants        Int?
  amenities           String[]     @default([])
  images              String[]     @default([])
  rules               String?      @db.Text
  cancellationPolicy  String?      @db.Text
  
  landlordId          String
  landlord            User         @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  
  isActive            Boolean      @default(true)
  viewCount           Int          @default(0)

  bookingMode         BookingMode  @default(REQUEST)
  minNights           Int          @default(1)
  maxNights           Int?
  advanceNoticeDays   Int          @default(0)
  checkInTime         String?      @default("15:00")
  checkOutTime        String?      @default("11:00")
  hourlyBookingEnabled Boolean     @default(false)
  pricePerHour        Float?
  citySlug            String?
  neighborhood        String?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relations
  bookings            Booking[]
  reviews             Review[]
  unavailableDates    UnavailableDate[]
  favorites           Favorite[]
  pricingRules        PricingRule[]
  eventPackages       EventPackage[]
  quoteRequests       QuoteRequest[]

  @@index([landlordId])
  @@index([type])
  @@index([isActive])
  @@index([citySlug])
  @@index([latitude, longitude])
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  listingId   String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model UnavailableDate {
  id          String   @id @default(cuid())
  listingId   String
  date        DateTime
  reason      String?
  
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
}

model Booking {
  id                  String         @id @default(cuid())
  bookingNumber       String         @unique @default(cuid()) // User-friendly booking reference
  
  listingId           String
  listing             Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  customerId          String
  customer            User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  checkInDate         DateTime
  checkOutDate        DateTime
  numberOfGuests      Int
  specialRequests     String?        @db.Text
  
  status              BookingStatus  @default(PENDING)
  totalPrice          Float          // Stored in cents
  depositAmount       Float?         // Stored in cents
  
  paymentId           String?        // Stripe payment intent ID
  paymentStatus       String         @default("pending")

  pricingType         BookingPricingType @default(DAILY)
  startTime           String?
  endTime             String?
  packageId           String?
  package             EventPackage?  @relation(fields: [packageId], references: [id], onDelete: SetNull)
  quoteId             String?        @unique
  quote               QuoteRequest?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  checkInInstructions String?        @db.Text
  accessCode          String?
  checkInQrToken      String?        @unique
  loyaltyDiscount     Float          @default(0)
  referralCredit      Float          @default(0)
  
  createdAt           DateTime       @default(now())
  updatedAt           DateTime     @updatedAt

  // Relations
  damageClaims        DamageClaim[]
  notifications       Notification[]
  conversation        Conversation?
  invoices            Invoice[]
  hostReview          HostReview?
  modificationRequests BookingModificationRequest[]

  @@index([customerId])
  @@index([listingId])
  @@index([status])
  @@index([checkInDate])
  @@index([checkOutDate])
}

model Review {
  id          String   @id @default(cuid())
  
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  rating      Int      // 1-5
  title       String
  comment     String   @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([listingId, userId])
  @@index([listingId])
  @@index([userId])
}

model DamageClaim {
  id              String       @id @default(cuid())
  claimNumber     String       @unique @default(cuid())
  
  bookingId       String
  booking         Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  reportedBy      String
  reportedByUser  User         @relation(fields: [reportedBy], references: [id], onDelete: Cascade)
  
  description     String       @db.Text
  images          String[]     @default([])
  estimatedCost   Float?       // Stored in cents
  
  status          DamageStatus @default(REPORTED)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([bookingId])
  @@index([reportedBy])
  @@index([status])
}

model Notification {
  id          String   @id @default(cuid())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bookingId   String?
  booking     Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  type        String   // "booking_confirmed", "damage_reported", etc.
  title       String
  message     String   @db.Text
  isRead      Boolean  @default(false)
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model StripeCustomer {
  id          String   @id @default(cuid())
  userId      String   @unique
  stripeId    String   @unique
  createdAt   DateTime @default(now())
}

model PricingRule {
  id               String          @id @default(cuid())
  listingId        String
  listing          Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  ruleType         PricingRuleType
  multiplier       Float?
  discountPercent  Float?
  minNights        Int?
  startDate        DateTime?
  endDate          DateTime?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())

  @@index([listingId])
}

model EventPackage {
  id          String           @id @default(cuid())
  listingId   String
  listing     Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name        String
  description String           @db.Text
  packageType EventPackageType @default(OTHER)
  basePrice   Float
  isActive    Boolean          @default(true)
  options     EventPackageOption[]
  bookings    Booking[]
  quotes      QuoteRequest[]
  createdAt   DateTime         @default(now())

  @@index([listingId])
}

model EventPackageOption {
  id          String       @id @default(cuid())
  packageId   String
  package     EventPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  isRequired  Boolean      @default(false)

  @@index([packageId])
}

model Conversation {
  id         String    @id @default(cuid())
  bookingId  String    @unique
  booking    Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId String
  customer   User      @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: Cascade)
  landlordId String
  landlord   User      @relation("LandlordConversations", fields: [landlordId], references: [id], onDelete: Cascade)
  messages   Message[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([customerId])
  @@index([landlordId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
}

model InvoiceSequence {
  year       Int @id
  lastNumber Int @default(0)
}

model Invoice {
  id            String      @id @default(cuid())
  invoiceNumber String      @unique
  bookingId     String
  booking       Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          InvoiceType
  subtotal      Float
  vatRate       Float       @default(0)
  vatAmount     Float       @default(0)
  total         Float
  currency      String      @default("XOF")
  issuedAt      DateTime    @default(now())

  @@index([bookingId])
  @@index([userId])
}

model SharedFavoriteList {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug      String               @unique
  title     String?
  isPublic  Boolean              @default(true)
  items     SharedFavoriteItem[]
  createdAt DateTime             @default(now())

  @@index([userId])
}

model SharedFavoriteItem {
  id        String             @id @default(cuid())
  listId    String
  list      SharedFavoriteList @relation(fields: [listId], references: [id], onDelete: Cascade)
  listingId String
  addedAt   DateTime           @default(now())

  @@unique([listId, listingId])
}

model QuoteRequest {
  id          String      @id @default(cuid())
  listingId   String
  listing     Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  customerId  String
  customer    User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  packageId   String?
  package     EventPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  eventType   String
  eventDate   DateTime
  guests      Int
  message     String      @db.Text
  status      QuoteStatus @default(PENDING)
  quotedPrice Float?
  hostReply   String?     @db.Text
  booking     Booking?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([listingId])
  @@index([customerId])
}

model BookingModificationRequest {
  id            String             @id @default(cuid())
  bookingId     String
  booking       Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User               @relation("ModificationRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  newCheckIn    DateTime
  newCheckOut   DateTime
  newGuests     Int?
  status        ModificationStatus @default(PENDING)
  hostReply     String?
  createdAt     DateTime           @default(now())

  @@index([bookingId])
}

model HostReview {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hostId     String
  host       User     @relation("HostReviews", fields: [hostId], references: [id], onDelete: Cascade)
  customerId String
  customer   User     @relation("GuestReviews", fields: [customerId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([hostId])
  @@index([customerId])
}

model LoyaltyAccount {
  id             String @id @default(cuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  points         Int    @default(0)
  totalBookings  Int    @default(0)
  updatedAt      DateTime @updatedAt
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   @unique
  createdAt DateTime @default(now())
}

model Referral {
  id              String   @id @default(cuid())
  referrerId      String
  referrer        User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId  String   @unique
  referred        User     @relation("Referred", fields: [referredUserId], references: [id], onDelete: Cascade)
  creditAmount    Float    @default(5000)
  redeemed        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([referrerId])
}

model LandlordOnboarding {
  id                   String  @id @default(cuid())
  userId               String  @unique
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileComplete      Boolean @default(false)
  firstListingCreated  Boolean @default(false)
  calendarConfigured   Boolean @default(false)
  pricingConfigured    Boolean @default(false)
  photosUploaded       Boolean @default(false)
  completedAt          DateTime?
  updatedAt            DateTime @updatedAt
}
